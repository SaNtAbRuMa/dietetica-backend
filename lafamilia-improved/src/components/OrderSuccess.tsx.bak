import { motion } from 'motion/react';
import { CheckCircle2, ShoppingBag } from 'lucide-react';

interface OrderSuccessProps {
  onBackToStore: () => void;
}

export function OrderSuccess({ onBackToStore }: OrderSuccessProps) {
  return (
    <motion.div 
      initial={{ opacity: 0, scale: 0.95 }}
      animate={{ opacity: 1, scale: 1 }}
      exit={{ opacity: 0, scale: 0.95 }}
      className="min-h-[70vh] flex items-center justify-center px-4 py-12"
    >
      <div className="max-w-md w-full bg-white rounded-3xl shadow-xl p-8 text-center border border-stone-100">
        <motion.div 
          initial={{ scale: 0 }}
          animate={{ scale: 1 }}
          transition={{ type: "spring", stiffness: 200, damping: 15, delay: 0.2 }}
          className="w-24 h-24 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-6"
        >
          <CheckCircle2 className="w-12 h-12 text-emerald-600" />
        </motion.div>
        
        <h1 className="text-3xl font-serif font-bold text-stone-900 mb-4">¡Pedido Confirmado!</h1>
        <p className="text-stone-600 mb-8 leading-relaxed">
          Gracias por elegir La Familia. Hemos recibido tu pedido y te enviamos un email con los detalles y los pasos a seguir.
        </p>

        <div className="bg-stone-50 rounded-2xl p-6 mb-8 text-left">
          <p className="text-sm text-stone-500 mb-1">Número de orden</p>
          <p className="font-mono font-bold text-stone-900 text-lg">#LF-{Math.floor(Math.random() * 100000).toString().padStart(5, '0')}</p>
        </div>

        <button 
          onClick={onBackToStore}
          className="w-full py-4 px-4 bg-stone-900 text-white rounded-xl font-medium hover:bg-stone-800 transition-colors flex items-center justify-center gap-2"
        >
          <ShoppingBag className="w-5 h-5" />
          Volver a la tienda
        </button>
      </div>
    </motion.div>
  );
}
